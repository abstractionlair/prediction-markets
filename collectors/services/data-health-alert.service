[Unit]
Description=Data system health alert — check all datasets for staleness/failures
After=network-online.target postgresql.service

[Service]
Type=oneshot
User=prediction-markets
WorkingDirectory=/opt/prediction-markets
EnvironmentFile=/etc/prediction-markets/kalshi-sync.env
ExecStart=/usr/bin/python3 -m data.health.alert --update
TimeoutStartSec=300
